From 5af638cda4c4cef92e4648d935f6b9e2172fc4ed Mon Sep 17 00:00:00 2001
From: Xpyy9 <wye_w01n@163.com>
Date: Mon, 15 Jun 2026 14:01:31 +0800
Subject: [PATCH 2/2] Florida: gum-temp-file-and-dylib-range-rename

Co-Authored-By: Claude <noreply@anthropic.com>
---
 gum/backend-darwin/gumcodesegment-darwin.c | 2 +-
 gum/backend-darwin/gumdarwinmapper.c       | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/gum/backend-darwin/gumcodesegment-darwin.c b/gum/backend-darwin/gumcodesegment-darwin.c
index ad574ff0..6bfd0801 100644
--- a/gum/backend-darwin/gumcodesegment-darwin.c
+++ b/gum/backend-darwin/gumcodesegment-darwin.c
@@ -404,7 +404,7 @@ gum_code_segment_try_realize (GumCodeSegment * self)
   gint res;
   fsignatures_t sigs;
 
-  self->fd = gum_file_open_tmp ("frida-XXXXXX.dylib", &dylib_path);
+  self->fd = gum_file_open_tmp ("fc-XXXXXX.dylib", &dylib_path);
   if (self->fd == -1)
     return FALSE;
 
diff --git a/gum/backend-darwin/gumdarwinmapper.c b/gum/backend-darwin/gumdarwinmapper.c
index 808ce526..9b380c03 100644
--- a/gum/backend-darwin/gumdarwinmapper.c
+++ b/gum/backend-darwin/gumdarwinmapper.c
@@ -1028,7 +1028,7 @@ gum_darwin_mapper_alloc_and_emit_runtime (GumDarwinMapper * self,
 
   strv_offsets[0] = 0;
   g_string_append_printf (strv_blob,
-      "frida_dylib_range=0x%" G_GINT64_MODIFIER "x,0x%" G_GSIZE_MODIFIER "x",
+      "fc_dylib_range=0x%" G_GINT64_MODIFIER "x,0x%" G_GSIZE_MODIFIER "x",
       base_address, size);
 
   for (i = 0; i != params->len; i++)
